# PostgreSQL
POSTGRES_DB=dentflow
POSTGRES_USER=dentflow
POSTGRES_PASSWORD=CHANGE_ME

# Spring Boot datasource (używane przez oba serwisy)
# W docker-compose: host = nazwa kontenera "postgres"
# Lokalnie bez Dockera: jdbc:postgresql://localhost:5432/dentflow
SPRING_DATASOURCE_URL=jdbc:postgresql://postgres:5432/dentflow
SPRING_DATASOURCE_USERNAME=dentflow
SPRING_DATASOURCE_PASSWORD=CHANGE_ME

# JWT
# WYMAGANE: min. 256-bitowy (32 znaki) losowy klucz
# Generowanie: openssl rand -hex 32
JWT_SECRET=CHANGE_ME
# Czas ważności tokenu
JWT_EXPIRATION=86400000 # 24h w ms

# SendGrid (email – potwierdzenia wizyt, przypomnienia)
# Klucz API z https://app.sendgrid.com/settings/api_keys
SENDGRID_API_KEY=SG.CHANGE_ME

# Mail
MAIL_HOST=smtp.sendgrid.net
MAIL_PORT=587
MAIL_USERNAME=apikey

# Supabase Storage (pliki pacjentów, zdjęcia)
# Project URL z Supabase Dashboard -> Settings -> API
SUPABASE_URL=https://YOUR_PROJECT.supabase.co
# service_role key (nie anon key) - dostęp do Storage
SUPABASE_SERVICE_KEY=CHANGE_ME
